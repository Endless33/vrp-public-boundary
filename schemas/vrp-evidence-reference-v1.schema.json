{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/vrp/schemas/vrp-evidence-reference-v1.schema.json",
  "title": "VRP Evidence Reference v1",
  "description": "Public, implementation-independent reference to a VRP evidence artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "evidence_id",
    "digest",
    "created_at",
    "retrieval_status"
  ],
  "properties": {
    "schema": {
      "const": "vrp.evidence-reference/v1"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "media_type": {
      "type": "string",
      "maxLength": 128,
      "examples": [
        "application/vnd.vrp.evidence+json"
      ]
    },
    "retrieval_status": {
      "type": "string",
      "enum": [
        "AVAILABLE",
        "RESTRICTED",
        "EXPIRED"
      ]
    },
    "public_metadata": {
      "type": "object",
      "maxProperties": 32,
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      }
    }
  }
}